<div class="meeting__calendar-container">
  <div class="meeting__calendar meeting__calendar__lg">
    <div class="meeting__calendar-month mb-4">
      <span><%= l(start_time, format: same_month? ? "%B" : "%b") %></span>
      <% unless same_month? %>
        <span class="meeting__calendar-separator">-</span>
        <span><%= l(end_time, format: "%b") %></span>
      <% end %>
    </div>
    <div class="meeting__calendar-day">
      <span><%= l(start_time, format: "%d") %></span>
      <% unless same_day? && same_month? %>
        <span class="meeting__calendar-separator">-</span>
        <span><%= l(end_time, format: "%d") %></span>
      <% end %>
    </div>
    <div class="meeting__calendar-year">
      <span><%= year %></span>
    </div>
  </div>

  <% if display_map? %>
    <%= static_map %>
  <% elsif online? %>
    <%= cell("decidim/address", meeting, online: true) %>
  <% else %>
    <%= cell("decidim/address", meeting) %>
  <% end %>
</div>
